---
import Layout from "../layouts/Layout.astro";
---

<Layout>
    <section class="w-full max-w-7xl mx-auto px-6 pt-6 md:pt-10 flex flex-col items-center flex-1 min-h-0 select-none">
        <div class="text-center max-w-5xl mx-auto flex flex-col items-center flex-shrink-0">
            <h1 class="font-['Averia_Serif_Libre'] text-[#0C3A8F] text-5xl sm:text-6xl md:text-7xl lg:text-[6.5rem] font-normal leading-[0.92] tracking-[-0.05em] animate-fade-in">
                Better Interface<br />for your agent
            </h1>
        </div>

        <div class="w-full flex justify-center mt-4 md:mt-8 flex-1 min-h-0 pb-2 md:pb-6 items-center">
            <img
                src="/com.svg"
                alt="pipper retro computer interface"
                class="w-full max-w-[520px] h-full max-h-[48svh] object-contain pointer-events-none animate-fade-in"
            />
        </div>
    </section>
</Layout>

<style>
    .animate-fade-in {
        animation: fade-in 1s ease-out forwards;
    }
</style>
